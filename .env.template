# Vertex Key API Gateway Configurations
# Get your API key from https://vertex-key.com
VERTEX_KEY_API_KEY=vai-your-api-key-here
VERTEX_KEY_API_BASE=https://vertex-key.com/v1

# Available models via Vertex Key gateway:
# aws/claude-sonnet-4-6   - Claude Sonnet 4.6 (Recommended, balanced)
# aws/claude-haiku-4-5    - Claude Haiku 4.5  (Fast & cheap)
# aws/qwen3-codex         - Qwen3 Codex       (Optimized for coding/testing)
# aws/minimax-m2.5        - MiniMax M2.5
# aws/glm-5               - GLM-5

# Per-Agent Model Configurations
# Each agent can use a different model independently
MODEL_ARCHITECT=aws/claude-sonnet-4-6
MODEL_CODER=aws/claude-sonnet-4-6
MODEL_REVIEWER=aws/claude-haiku-4-5
MODEL_TESTER=aws/qwen3-codex
